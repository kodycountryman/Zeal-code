{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "resourceClass": "medium",
      "builderEnvironment": {
        "image": "latest",
        "node": "22.14.0"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}