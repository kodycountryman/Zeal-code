{
  "expo": {
    "name": "zeal+",
    "slug": "7s0at91o0glp1nhgft32r",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zeal-plus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kodycountryman.zealplus",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Zeal reads your steps, calories, and heart rate to enhance your training readiness and insights.",
        "NSHealthUpdateUsageDescription": "Zeal writes your completed workouts to Apple Health to keep your health records in sync.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.kodycountryman.zealplus",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.WRITE_EXERCISE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#f87116",
          "iosDisplayInForeground": true,
          "androidMode": "default",
          "androidCollapsedTitle": "Zeal"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "85cf0e7c-15c9-4b6d-8554-6f54d3cd9c38"
      }
    },
    "owner": "kodycountryman"
  }
}
